---
import { site } from '../data/site';
import Logo from './Logo.astro';

const year = new Date().getFullYear();

const behandelingenLinks = [
  { label: 'Gezichtsbehandelingen', href: '/gezichtsbehandeling/' },
  { label: 'Microdermabrasie', href: '/microdermabrasie/' },
  { label: 'Waxen', href: '/waxen/' },
  { label: 'Wenkbrauwen', href: '/wenkbrauwen-epileren/' },
  { label: 'Losse behandelingen', href: '/behandelingen/' },
];

const salonLinks = [
  { label: 'Over mij', href: '/over-mij/' },
  { label: 'Merken', href: '/merken/' },
  { label: 'Reviews', href: '/reviews/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Afspraak maken', href: '/afspraak-maken/' },
];
---

<footer class="px-6 pb-8 pt-12 md:px-10 md:pt-16">
  <div class="border-t border-line pt-12 md:pt-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-8">
      <div class="md:col-span-4">
        <Logo class="items-start" imgClass="h-10" />
        <p class="mt-4 max-w-xs text-[13px] leading-relaxed text-ink-soft">
          {site.name} is een Anbos gecertificeerde schoonheidssalon gevestigd op de {site.address.street} aan de rand
          van het centrum in {site.address.city}.
        </p>
        <ul class="mt-6 space-y-1.5 text-[13px] text-ink-soft">
          <li><a href={site.address.mapsUrl} target="_blank" rel="noopener" class="hover:text-ink">{site.address.street}, {site.address.postalCode} {site.address.city}</a></li>
          <li><a href={`mailto:${site.contact.email}`} class="hover:text-ink">{site.contact.email}</a></li>
          <li><a href={site.contact.phoneHref} class="hover:text-ink">{site.contact.phone}</a></li>
        </ul>
        <p class="mt-4 text-[11px] text-ink-soft/70">
          KVK-nummer: {site.kvk}<br />
          BTW nummer: {site.btw}
        </p>
        <a href={site.anbosUrl} target="_blank" rel="noopener" class="mt-6 inline-block">
          <img src="/images/anbos.png" alt="Anbos gediplomeerd schoonheidsspecialist" class="h-16 w-auto rounded-lg" />
        </a>
      </div>

      <div class="md:col-span-3">
        <h4 class="mb-5 text-[12px] font-semibold uppercase tracking-[0.08em] text-ink">Behandelingen</h4>
        <ul class="space-y-3">
          {
            behandelingenLinks.map((link) => (
              <li>
                <a href={link.href} class="text-[13px] text-ink-soft transition-colors hover:text-ink">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="md:col-span-3">
        <h4 class="mb-5 text-[12px] font-semibold uppercase tracking-[0.08em] text-ink">Salon</h4>
        <ul class="space-y-3">
          {
            salonLinks.map((link) => (
              <li>
                <a href={link.href} class="text-[13px] text-ink-soft transition-colors hover:text-ink">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="md:col-span-2">
        <a
          href={site.googleReviewUrl}
          target="_blank"
          rel="noopener nofollow"
          class="flex items-center gap-2 rounded-2xl border border-line bg-bg-soft px-4 py-3"
        >
          <img src="https://cdn.trustindex.io/assets/platform/Google/icon.svg" alt="Google" width="20" height="20" loading="lazy" />
          <span class="flex flex-col">
            <span class="text-[11px] text-ink-soft">Google beoordeling</span>
            <span class="flex items-center gap-1 text-[12px] font-semibold text-ink">
              5.0
              <span class="flex gap-0.5">
                {Array.from({ length: 5 }).map(() => (
                  <img src="https://cdn.trustindex.io/assets/platform/Google/star/f.svg" alt="" width="12" height="12" loading="lazy" />
                ))}
              </span>
            </span>
          </span>
        </a>
      </div>
    </div>

    <div class="mt-16 grid grid-cols-1 items-center gap-4 border-t border-line pt-6 md:mt-24 md:grid-cols-3">
      <p class="text-[12px] text-ink-soft">Copyright &copy; {year} {site.name}. Alle rechten voorbehouden.</p>
      <div class="flex gap-5 md:justify-center">
        <a href="/algemene-voorwaarden/" class="text-[12px] text-ink-soft hover:text-ink">Algemene voorwaarden</a>
        <a href="/algemene-voorwaarden/#annuleringsvoorwaarden" class="text-[12px] text-ink-soft hover:text-ink">Annuleringsvoorwaarden</a>
        <a href="/privacyverklaring/" class="text-[12px] text-ink-soft hover:text-ink">Privacyverklaring</a>
      </div>
      <div class="flex items-center gap-4 md:justify-end">
        <a
          href={site.social.facebook}
          target="_blank"
          rel="noopener"
          aria-label="Facebook"
          class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-soft transition-colors hover:border-ink/40 hover:text-ink"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path d="M13.5 21v-8.1h2.7l.4-3.15h-3.1V7.77c0-.91.25-1.53 1.56-1.53h1.66V3.42A22.3 22.3 0 0014.1 3.3c-2.3 0-3.87 1.4-3.87 3.98v2.47H8v3.15h2.23V21h3.27z" />
          </svg>
        </a>
        <a
          href={site.social.instagram}
          target="_blank"
          rel="noopener"
          aria-label="Instagram"
          class="flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-soft transition-colors hover:border-ink/40 hover:text-ink"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <rect x="3.5" y="3.5" width="17" height="17" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17" cy="7" r="0.9" fill="currentColor" stroke="none" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
