---
import { site, treatments } from '../data/site';

const year = new Date().getFullYear();

const columns = [
  {
    title: 'Behandelingen',
    links: treatments.map((t) => ({ label: t.title, href: `/${t.slug}/` })),
  },
  {
    title: 'Salon',
    links: [
      { label: 'Over mij', href: '/over-mij/' },
      { label: 'Merken', href: '/merken/' },
      { label: 'Reviews', href: '/reviews/' },
      { label: 'Blog', href: '/blog/' },
    ],
  },
  {
    title: 'Contact',
    links: [
      { label: 'Contact', href: '/contact/' },
      { label: 'Afspraak maken', href: '/afspraak-maken/' },
    ],
  },
  {
    title: 'Juridisch',
    links: [
      { label: 'Algemene voorwaarden', href: '/algemene-voorwaarden/' },
      { label: 'Annuleringsvoorwaarden', href: '/algemene-voorwaarden/' },
    ],
  },
];
---

<footer class="px-6 pb-8 pt-12 md:px-10 md:pt-16">
  <div class="border-t border-line pt-12 md:pt-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-10">
      <div class="md:col-span-5">
        <a href="/" class="block font-display text-2xl font-light tracking-tight text-ink">
          {site.name}
        </a>
        <p class="mt-4 max-w-xs text-[13px] leading-relaxed text-ink-soft">
          Anbos gecertificeerde schoonheidssalon gevestigd op de {site.address.street} aan de rand
          van het centrum in {site.address.city}.
        </p>
        <ul class="mt-6 space-y-1.5 text-[13px] text-ink-soft">
          <li><a href={site.address.mapsUrl} target="_blank" rel="noopener" class="hover:text-ink">{site.address.street}, {site.address.postalCode} {site.address.city}</a></li>
          <li><a href={`mailto:${site.contact.email}`} class="hover:text-ink">{site.contact.email}</a></li>
          <li><a href={site.contact.phoneHref} class="hover:text-ink">{site.contact.phone}</a></li>
        </ul>
        <p class="mt-4 text-[11px] text-ink-soft/70">
          KVK-nummer: {site.kvk}<br />
          BTW nummer: {site.btw}
        </p>
      </div>

      <div class="grid grid-cols-2 gap-10 md:col-span-7 md:grid-cols-4 md:gap-8">
        {
          columns.map((col) => (
            <div>
              <h4 class="mb-5 text-[12px] font-semibold uppercase tracking-[0.08em] text-ink">{col.title}</h4>
              <ul class="space-y-3">
                {col.links.map((link) => (
                  <li>
                    <a href={link.href} class="text-[13px] text-ink-soft transition-colors hover:text-ink">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-16 grid grid-cols-1 items-center gap-4 border-t border-line pt-6 md:mt-24 md:grid-cols-3">
      <p class="text-[12px] text-ink-soft">Copyright &copy; {year} {site.name}</p>
      <div class="flex gap-5 md:justify-center">
        <a href={site.social.facebook} target="_blank" rel="noopener" class="text-[12px] uppercase tracking-[0.1em] text-ink-soft hover:text-ink">
          Facebook
        </a>
      </div>
    </div>
  </div>
</footer>
