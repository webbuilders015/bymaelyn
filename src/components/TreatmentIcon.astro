---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = 'h-7 w-7' } = Astro.props;
---

{
  name === 'facial' && (
    <svg viewBox="0 0 48 48" class={className} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M24 6c-8 0-13 6.5-13 15 0 9 5 15 9 17.5 1 .6 2 1 4 1s3-.4 4-1c4-2.5 9-8.5 9-17.5 0-8.5-5-15-13-15z" />
      <path d="M17 20c0-1.2 1-2 2-2s2 .8 2 2" />
      <path d="M27 20c0-1.2 1-2 2-2s2 .8 2 2" />
      <path d="M20 28c1.4 1.2 2.6 1.8 4 1.8s2.6-.6 4-1.8" />
      <path d="M24 22.5v4" />
    </svg>
  )
}

{
  name === 'peeling' && (
    <svg viewBox="0 0 48 48" class={className} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M24 6c5 6 9 12.5 9 18a9 9 0 1 1-18 0c0-5.5 4-12 9-18z" />
      <path d="M20.5 26c0 2 1.5 3.5 3.5 3.5" />
    </svg>
  )
}

{
  name === 'microderm' && (
    <svg viewBox="0 0 48 48" class={className} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="18" cy="18" r="9" />
      <path d="M24.5 24.5L40 40" />
      <path d="M36 36l4-4" />
      <path d="M14 18a4 4 0 0 1 4-4" />
    </svg>
  )
}

{
  name === 'wax' && (
    <svg viewBox="0 0 48 48" class={className} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M17 8h14l-2 8H19l-2-8z" />
      <path d="M18 16l1.5 20a4.5 4.5 0 0 0 4.5 4 4.5 4.5 0 0 0 4.5-4L30 16" />
      <path d="M21 24h6" />
      <path d="M21.5 30h5" />
    </svg>
  )
}

{
  name === 'brows' && (
    <svg viewBox="0 0 48 48" class={className} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 20c3-4 8-6.5 12-6.5s8 1.5 10 4" />
      <path d="M27 20c3-4 7-6.5 11-6.5" />
      <path d="M12 30c2.5-1.5 5-2 7-2" />
      <path d="M14 33c4-6 8-9 14-13" />
    </svg>
  )
}

{
  name === 'gift' && (
    <svg viewBox="0 0 48 48" class={className} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <rect x="8" y="18" width="32" height="9" rx="1.5" />
      <rect x="10.5" y="27" width="27" height="15" rx="1.5" />
      <path d="M24 18v24" />
      <path d="M24 18c-2-6-6-9-9-9-2.5 0-4.5 2-4.5 4.5s3 4.5 6.5 4.5h7z" />
      <path d="M24 18c2-6 6-9 9-9 2.5 0 4.5 2 4.5 4.5s-3 4.5-6.5 4.5h-7z" />
    </svg>
  )
}
