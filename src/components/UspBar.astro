---
import { site } from '../data/site';
---

<div class="border-b border-line bg-bg">
  <!-- Desktop: all USPs inline -->
  <ul class="mx-auto hidden max-w-6xl flex-wrap items-center justify-center gap-x-10 gap-y-2 px-6 py-4 text-[14px] text-ink-soft sm:flex">
    {
      site.usps.map((usp) => (
        <li class="flex items-center gap-2">
          <svg viewBox="0 0 20 20" class="h-4 w-4 shrink-0 text-emerald-500" fill="currentColor" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M16.704 5.29a1 1 0 010 1.415l-7.25 7.25a1 1 0 01-1.414 0l-3.25-3.25a1 1 0 111.414-1.415l2.543 2.543 6.543-6.543a1 1 0 011.414 0z"
              clip-rule="evenodd"
            />
          </svg>
          {usp}
        </li>
      ))
    }
  </ul>

  <!-- Mobile: auto-advancing carousel -->
  <div id="usp-carousel" class="relative overflow-hidden px-6 py-4 sm:hidden">
    <div class="relative h-6">
      {
        site.usps.map((usp, i) => (
          <div
            class="usp-slide absolute inset-0 flex items-center justify-center gap-2 text-center text-[14px] text-ink-soft transition-opacity duration-500"
            style={i === 0 ? 'opacity:1' : 'opacity:0'}
          >
            <svg viewBox="0 0 20 20" class="h-4 w-4 shrink-0 text-emerald-500" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M16.704 5.29a1 1 0 010 1.415l-7.25 7.25a1 1 0 01-1.414 0l-3.25-3.25a1 1 0 111.414-1.415l2.543 2.543 6.543-6.543a1 1 0 011.414 0z"
                clip-rule="evenodd"
              />
            </svg>
            <span>{usp}</span>
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  const carousel = document.getElementById('usp-carousel');
  const slides = carousel?.querySelectorAll<HTMLElement>('.usp-slide');

  if (slides && slides.length > 1) {
    let index = 0;
    setInterval(() => {
      slides[index].style.opacity = '0';
      index = (index + 1) % slides.length;
      slides[index].style.opacity = '1';
    }, 3500);
  }
</script>
