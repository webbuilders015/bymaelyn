---
import { site, mainNav } from '../data/site';
---

<header class="sticky top-0 z-50 border-b border-line/70 bg-bg/90 backdrop-blur">
  <nav class="grid grid-cols-[1fr_auto_1fr] items-center px-6 py-5 md:px-10" aria-label="Hoofdmenu">
    <ul class="hidden items-center gap-8 text-[12px] uppercase tracking-[0.14em] lg:flex">
      {
        mainNav.slice(0, 3).map((item) => (
          <li class="group relative">
            <a href={item.href} class="transition-opacity duration-300 hover:opacity-60">
              {item.label}
            </a>
            {item.children && (
              <div class="invisible absolute left-0 top-full min-w-48 translate-y-1 border border-line bg-bg p-2 opacity-0 shadow-lg shadow-ink/5 transition-all duration-150 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
                {item.children.map((child) => (
                  <a href={child.href} class="block px-4 py-2 text-[12px] normal-case tracking-normal text-ink-soft hover:bg-bg-soft hover:text-ink">
                    {child.label}
                  </a>
                ))}
              </div>
            )}
          </li>
        ))
      }
    </ul>

    <a href="/" class="col-start-2 justify-self-center font-display text-[28px] font-light leading-none tracking-tight text-ink md:text-[34px]">
      {site.name}
    </a>

    <div class="col-start-3 hidden items-center justify-end gap-8 text-[12px] uppercase tracking-[0.14em] lg:flex">
      {
        mainNav.slice(3).map((item) => (
          <a href={item.href} class="transition-opacity duration-300 hover:opacity-60">
            {item.label}
          </a>
        ))
      }
      <a
        href="/afspraak-maken/"
        class="inline-flex h-10 items-center bg-accent px-6 text-[12px] tracking-[0.1em] text-bg transition-colors duration-300 hover:bg-accent-dark"
      >
        Afspraak maken
      </a>
    </div>

    <button
      id="menu-toggle"
      type="button"
      class="col-start-1 flex flex-col items-stretch justify-center gap-[6px] w-7 h-7 lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block h-[2px] w-full bg-ink"></span>
      <span class="block h-[2px] w-full bg-ink"></span>
      <span class="block h-[2px] w-full bg-ink"></span>
    </button>
    <div class="col-start-3 justify-self-end lg:hidden">
      <a href="/afspraak-maken/" class="inline-flex h-9 items-center bg-accent px-4 text-[11px] tracking-[0.1em] text-bg">
        Boeken
      </a>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-line lg:hidden">
    <ul class="flex flex-col gap-1 px-6 py-6 text-[15px] tracking-tight">
      {
        mainNav.map((item) => (
          <a href={item.href} class="block px-2 py-2 text-ink-soft hover:text-ink">
            {item.label}
          </a>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
  });
</script>
