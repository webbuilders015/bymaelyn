---
import { mainNav } from '../data/site';
import Logo from './Logo.astro';
---

<header class="sticky top-0 z-50 border-b border-line/70 bg-bg/90 backdrop-blur">
  <!-- Mobile: hamburger left, logo centered, book button right -->
  <nav class="grid grid-cols-3 items-center px-6 py-3 lg:hidden" aria-label="Hoofdmenu mobiel">
    <button
      id="menu-toggle"
      type="button"
      class="flex flex-col items-stretch justify-center gap-[6px] w-7 h-7 justify-self-start"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block h-[2px] w-full bg-ink"></span>
      <span class="block h-[2px] w-full bg-ink"></span>
      <span class="block h-[2px] w-full bg-ink"></span>
    </button>

    <Logo class="justify-self-center" imgClass="h-11" />

    <a
      href="/afspraak-maken/"
      class="justify-self-end inline-flex h-9 items-center rounded-full bg-accent px-4 text-[11px] tracking-[0.1em] text-bg"
    >
      Boeken
    </a>
  </nav>

  <!-- Desktop: logo left, nav center/right, book button right -->
  <nav class="hidden items-center justify-between gap-6 px-10 py-4 lg:flex" aria-label="Hoofdmenu">
    <Logo imgClass="h-9" />

    <ul class="flex items-center gap-7 text-[12px] uppercase tracking-[0.12em]">
      {
        mainNav.map((item) => (
          <li class="group relative">
            <a
              href={item.href}
              class="transition-opacity duration-300 hover:opacity-60"
              target={item.href.startsWith('http') ? '_blank' : undefined}
              rel={item.href.startsWith('http') ? 'noopener' : undefined}
            >
              {item.label}
            </a>
            {item.children && (
              <div class="invisible absolute left-0 top-full min-w-48 translate-y-1 rounded-2xl border border-line bg-bg p-2 opacity-0 shadow-lg shadow-ink/5 transition-all duration-150 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    target={child.href.startsWith('http') ? '_blank' : undefined}
                    rel={child.href.startsWith('http') ? 'noopener' : undefined}
                    class="block rounded-xl px-4 py-2 text-[12px] normal-case tracking-normal text-ink-soft hover:bg-bg-soft hover:text-ink"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            )}
          </li>
        ))
      }
    </ul>

    <a
      href="/afspraak-maken/"
      class="inline-flex h-10 items-center rounded-full bg-accent px-6 text-[12px] tracking-[0.1em] text-bg transition-colors duration-300 hover:bg-accent-dark"
    >
      Afspraak maken
    </a>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-line lg:hidden">
    <div id="menu-panel-root" class="menu-panel px-6 py-4">
      <ul class="flex flex-col gap-1 text-[15px] tracking-tight">
        {
          mainNav.map((item, i) => (
            <li>
              {item.children ? (
                <button
                  type="button"
                  class="menu-panel-trigger flex w-full items-center justify-between px-2 py-2.5 text-left text-ink-soft transition-colors hover:text-ink"
                  data-target={`menu-panel-${i}`}
                >
                  <span>{item.label}</span>
                  <svg viewBox="0 0 20 20" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M7.5 4.5l6 5.5-6 5.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>
              ) : (
                <a
                  href={item.href}
                  target={item.href.startsWith('http') ? '_blank' : undefined}
                  rel={item.href.startsWith('http') ? 'noopener' : undefined}
                  class="block px-2 py-2.5 text-ink-soft hover:text-ink"
                >
                  {item.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </div>

    {
      mainNav.map(
        (item, i) =>
          item.children && (
            <div id={`menu-panel-${i}`} class="menu-panel hidden px-6 py-4">
              <button
                type="button"
                class="menu-panel-back mb-3 flex items-center gap-2 px-2 py-2 text-[12px] uppercase tracking-[0.1em] text-ink-soft transition-colors hover:text-ink"
              >
                <svg viewBox="0 0 20 20" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M12.5 4.5l-6 5.5 6 5.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {item.label}
              </button>
              <ul class="flex flex-col gap-1 text-[15px] tracking-tight">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      target={child.href.startsWith('http') ? '_blank' : undefined}
                      rel={child.href.startsWith('http') ? 'noopener' : undefined}
                      class="block px-2 py-2.5 text-ink-soft hover:text-ink"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
      )
    }
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  function resetToRootPanel() {
    menu?.querySelectorAll<HTMLElement>('.menu-panel').forEach((panel) => panel.classList.add('hidden'));
    document.getElementById('menu-panel-root')?.classList.remove('hidden');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    if (isOpen) resetToRootPanel();
  });

  menu?.querySelectorAll<HTMLElement>('.menu-panel-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.target;
      if (!targetId) return;
      document.getElementById('menu-panel-root')?.classList.add('hidden');
      document.getElementById(targetId)?.classList.remove('hidden');
    });
  });

  menu?.querySelectorAll<HTMLElement>('.menu-panel-back').forEach((btn) => {
    btn.addEventListener('click', () => {
      btn.closest('.menu-panel')?.classList.add('hidden');
      document.getElementById('menu-panel-root')?.classList.remove('hidden');
    });
  });
</script>
