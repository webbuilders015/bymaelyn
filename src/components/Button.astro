---
interface Props {
  href: string;
  variant?: 'primary' | 'outline';
  class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const base =
  'inline-flex h-12 items-center justify-center gap-2 px-8 text-[13px] tracking-[0.08em] uppercase transition-colors duration-300';
const variants = {
  primary: 'bg-accent text-bg hover:bg-accent-dark',
  outline: 'border border-ink/20 text-ink hover:bg-ink hover:text-bg',
};
---

<a href={href} class={`${base} ${variants[variant]} ${className}`}>
  <slot />
</a>
