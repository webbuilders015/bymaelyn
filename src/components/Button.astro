---
interface Props {
  href: string;
  variant?: 'primary' | 'outline';
  class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-medium tracking-wide transition-colors duration-200';
const variants = {
  primary: 'bg-terracotta text-cream hover:bg-terracotta-dark',
  outline: 'border border-ink/20 text-ink hover:border-terracotta hover:text-terracotta-dark',
};
---

<a href={href} class={`${base} ${variants[variant]} ${className}`}>
  <slot />
</a>
