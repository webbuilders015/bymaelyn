---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog - Art of Beauty by Maelyn"
  description="Tips, uitleg en inspiratie over huidverzorging, gezichtsbehandelingen en skincare van schoonheidssalon Art of Beauty by Maelyn in Delft."
>
  <PageHero
    eyebrow="Blog"
    title="Skincare-tips & huidverzorging"
    lead="Praktische uitleg en inspiratie over gezichtsbehandelingen, huidverzorging en de behandelingen bij Art of Beauty by Maelyn."
  />

  <section class="mx-auto max-w-5xl px-6 py-16">
    {posts.length === 0 && <p class="text-ink-soft">Binnenkort verschijnen hier de eerste artikelen.</p>}
    <div class="grid gap-6 sm:grid-cols-2">
      {
        posts.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="group flex flex-col overflow-hidden rounded-2xl border border-line bg-bg-soft transition-colors hover:border-ink/40"
          >
            <div class="aspect-[16/10] w-full overflow-hidden">
              <img
                src={post.data.heroImage}
                alt={post.data.heroAlt}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="flex flex-1 flex-col p-6">
              <span class="text-xs uppercase tracking-wide text-accent">
                {post.data.tags[0] ?? 'Skincare'}
              </span>
              <span class="mt-2 font-display text-xl text-ink">{post.data.title}</span>
              <span class="mt-2 text-sm text-ink-soft">{post.data.description}</span>
              <span class="mt-4 text-xs text-ink-soft/70">
                Maelyn &middot; {post.data.pubDate.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
