---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { site } from '../../data/site';
---

<BaseLayout
  title="Contact - Art of Beauty by Maelyn"
  description="Meer informatie of vragen over onze schoonheidsbehandelingen? Neem hier contact op met onze schoonheidssalon in Delft!"
  schema={{
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact - Art of Beauty by Maelyn',
    url: new URL('/contact/', site.url).toString(),
  }}
>
  <PageHero eyebrow="Contact" title="Neem contact met ons op" />

  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="font-display text-2xl text-ink">Contact opnemen</h2>
        <p class="mt-3 text-ink-soft">
          Voor vragen over onze schoonheidssalon of vragen aan de schoonheidsspecialiste kun je
          contact opnemen via onderstaand contactformulier. We streven ernaar binnen 24 uur
          antwoord te geven op je vraag.
        </p>

        <form id="contact-form" class="mt-6 space-y-4" method="post">
          <div>
            <label for="name" class="block text-sm font-medium text-ink">Naam</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="mt-1 w-full rounded-xl rounded-2xl border border-line bg-bg px-4 py-3 text-ink outline-none focus:border-accent"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-ink">E-mailadres</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="mt-1 w-full rounded-xl rounded-2xl border border-line bg-bg px-4 py-3 text-ink outline-none focus:border-accent"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-ink">Telefoonnummer</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="mt-1 w-full rounded-xl rounded-2xl border border-line bg-bg px-4 py-3 text-ink outline-none focus:border-accent"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-ink">Je bericht</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="mt-1 w-full rounded-xl rounded-2xl border border-line bg-bg px-4 py-3 text-ink outline-none focus:border-accent"
            ></textarea>
          </div>
          <button
            type="submit"
            class="rounded-full bg-accent px-6 py-3 text-sm font-medium text-bg transition-colors hover:bg-accent-dark disabled:opacity-60"
          >
            Versturen
          </button>
          <p id="contact-form-status" class="text-sm" role="status"></p>
        </form>
      </div>

      <div>
        <h2 class="font-display text-2xl text-ink">Contactinformatie</h2>
        <ul class="mt-4 space-y-2 text-ink-soft">
          <li>
            <a href={site.address.mapsUrl} target="_blank" rel="noopener" class="hover:text-accent">
              {site.address.street}, {site.address.postalCode} {site.address.city}
            </a>
          </li>
          <li>
            <a href={site.contact.phoneHref} class="hover:text-accent">{site.contact.phone}</a>
          </li>
          <li>
            <a href={`mailto:${site.contact.email}`} class="hover:text-accent">{site.contact.email}</a>
          </li>
        </ul>

        <h3 class="mt-6 font-medium text-ink">Openingstijden</h3>
        <ul class="mt-2 space-y-1 text-ink-soft">
          {
            site.openingHours.map((o) => (
              <li class="flex justify-between gap-4">
                <span>{o.day}</span>
                <span>{o.hours}</span>
              </li>
            ))
          }
        </ul>

        <h3 class="mt-6 font-medium text-ink">Parkeren</h3>
        <p class="mt-2 text-ink-soft">
          In de omgeving van de schoonheidssalon is parkeren alleen toegestaan met een
          parkeervergunning. Je kunt het beste parkeren in de Phoenix garage of de Prinsenhof
          garage. Vanaf de Phoenix garage is het ongeveer 5 minuten lopen naar onze
          schoonheidssalon. Vanuit de Prinsenhof garage volg je de uitgang Bagijnhof en steek je
          alleen nog de trambaan over.
        </p>
        <p class="mt-3 text-ink-soft">
          De schoonheidssalon is het beste te bereiken per fiets of scooter — hiervoor is
          parkeergelegenheid voor de deur. Ook met het openbaar vervoer is de salon goed
          bereikbaar: het centraal station ligt op loopafstand en de tramhalte zit vlakbij.
        </p>

        <div class="mt-6 overflow-hidden rounded-2xl border border-line">
          <iframe
            title="Locatie Art of Beauty by Maelyn op de kaart"
            src="https://maps.google.com/maps?q=Art%20of%20Beauty%20by%20Maelyn%20Bagijnhof%20Delft&t=m&z=15&output=embed&iwloc=near"
            width="100%"
            height="320"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-form-status');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (button) button.disabled = true;
    if (status) {
      status.textContent = 'Bezig met versturen...';
      status.className = 'text-sm text-ink-soft';
    }

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });
      const result = await response.json();

      if (response.ok && result.success) {
        form.reset();
        if (status) {
          status.textContent = 'Bedankt! Je bericht is verstuurd, we nemen snel contact op.';
          status.className = 'text-sm text-emerald-600';
        }
      } else {
        if (status) {
          status.textContent = result.error || 'Versturen is niet gelukt. Probeer het later opnieuw.';
          status.className = 'text-sm text-red-600';
        }
      }
    } catch {
      if (status) {
        status.textContent = 'Versturen is niet gelukt. Controleer je internetverbinding.';
        status.className = 'text-sm text-red-600';
      }
    } finally {
      if (button) button.disabled = false;
    }
  });
</script>
