---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { brands, site } from '../../data/site';

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: brands.map((b, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Brand',
      name: b.title,
      description: b.short,
      url: new URL(`/${b.slug}/`, site.url).toString(),
      logo: new URL(b.logo, site.url).toString(),
    },
  })),
};
---

<BaseLayout
  title="Merken - Art of Beauty by Maelyn"
  description="Wij werken in onze schoonheidssalon in Delft met de merken Paula's Choice en Skeyndor voor huidverbeterende en effectieve huidverzorging."
  schema={itemListSchema}
>
  <PageHero eyebrow="Merken" title="De merken waar wij mee werken" />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <div class="grid gap-6 sm:grid-cols-2">
      {
        brands.map((b) => (
          <a
            href={`/${b.slug}/`}
            class="group flex flex-col items-center rounded-2xl border border-line bg-bg-soft p-10 text-center transition-colors hover:border-ink/40"
          >
            <img src={b.logo} alt={b.title} class="h-12 w-auto object-contain" loading="lazy" />
            <span class="mt-6 font-display text-xl text-ink group-hover:text-accent">
              {b.title}
            </span>
            <span class="mt-3 text-ink-soft">{b.short}</span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
