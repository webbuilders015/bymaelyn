---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { brands } from '../../data/site';
---

<BaseLayout
  title="Merken - Art of Beauty by Maelyn"
  description="Wij werken in onze schoonheidssalon in Delft met de merken Paula's Choice en Skeyndor voor huidverbeterende en effectieve huidverzorging."
>
  <PageHero eyebrow="Merken" title="De merken waar wij mee werken" />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <div class="grid gap-6 sm:grid-cols-2">
      {
        brands.map((b) => (
          <a
            href={`/${b.slug}/`}
            class="group flex flex-col rounded-2xl border border-line bg-cream-dark/40 p-8 transition-shadow hover:shadow-lg hover:shadow-ink/5"
          >
            <span class="font-display text-xl text-ink group-hover:text-terracotta-dark">
              {b.title}
            </span>
            <span class="mt-3 text-ink-soft">{b.short}</span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
