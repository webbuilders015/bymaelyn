---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Button from '../../components/Button.astro';
import { site } from '../../data/site';

const baseTreatments = [
  {
    name: 'Art of Beauty Treatment',
    duration: '50-60 min',
    price: '€62,50',
    description:
      'Huidverzorgende gezichtsbehandeling die zich richt op de reiniging en hygiëne van de huid, geschikt voor elk huidtype. Door de dubbele reinigingsmethode wordt de huid optimaal gereinigd, gezuiverd en voelt de huid weer fris en comfortabel aan. Deze behandeling kan worden uitgevoerd met Paula’s Choice of Skeyndor en is eventueel uit te breiden met onze losse behandelingen.',
    steps: [
      'Huidanalyse',
      'Reiniging fase 1',
      'Reiniging fase 2',
      'Peeling',
      'Onzuiverheden verwijderen',
      'Gezicht- of nek-/schoudermassage',
      'Masker',
      'Dag- of nachtverzorging',
      'Adviesgesprek',
    ],
  },
  {
    name: 'Pure Cleanse Treatment (12 - 20 jaar)',
    duration: '30-45 min',
    price: '€41,50',
    description:
      'Speciaal gericht op tieners met een onrustige huid met onzuiverheden en/of ontstekingen. We gebruiken milde producten met een ontstekingsremmende, zuiverende en kalmerende werking, waardoor de huid minder rood en geïrriteerd is na afloop.',
    steps: ['Huidanalyse', 'Reiniging', 'Milde peeling / scrub', 'Onzuiverheden verwijderen', 'Masker', 'Dagverzorging'],
  },
];

const powerTreatments = [
  {
    slug: 'power-oxygen-treatment',
    name: 'Power Oxygen Treatment',
    isNew: true,
    tagline: 'Detox & bescherming voor een frisse, vermoeide huid.',
    duration: '60-75 min',
    price: '€77,50',
    description:
      'Huidverbeterende gezichtsbehandeling op basis van een zuurstofrijk complex. Ideaal voor een doffe, vermoeide huid die last heeft van een drukke levensstijl of stadslucht. Deze behandeling laat de huid als het ware weer ademen en werkt als een detox- en energieboost.',
    idealFor: ['Rokers', 'Een drukke levensstijl', 'Stadslucht en vervuiling', 'Doffe, vermoeide huid'],
    result: ['Frisse uitstraling', 'Directe glow', 'Gezonde huidbarrière', 'Bescherming tegen vrije radicalen'],
    diamondCompatible: true,
    steps: [
      'Huidanalyse',
      'Reiniging',
      'Peeling',
      'Onzuiverheden verwijderen',
      'Wenkbrauwen harsen / epileren',
      'Ampullen met Oxygen Complex',
      'Uitgebreide gezicht-, nek- en schoudermassage',
      'Masker',
      'Dag- of nachtverzorging',
      'Adviesgesprek',
    ],
  },
  {
    slug: 'power-hydration-treatment',
    name: 'Power Hydration Treatment',
    previousName: 'Power Hyaluronic Treatment',
    tagline: 'Intensieve hydratatie voor een zachte, volle en comfortabele huid.',
    duration: '60-75 min',
    price: '€77,50',
    description:
      'Huidverbeterende gezichtsbehandeling op basis van hyaluronzuur. Deze krachtige vochtbinder herstelt de natuurlijke vochtgraad van de huid en maakt een droge of vochtarme huid met (droogte) lijntjes weer comfortabel en volumineus. Geschikt voor elk huidtype.',
    idealFor: ['Droge huid', 'Vochtarme huid', 'Trekkerig gevoel', 'Fijne droogtelijntjes'],
    result: ['Intens gehydrateerde huid', 'Zachtere huid', 'Vollere uitstraling', 'Minder droogtelijntjes'],
    diamondCompatible: true,
    steps: [
      'Huidanalyse',
      'Reiniging',
      'Peeling',
      'Onzuiverheden verwijderen',
      'Wenkbrauwen harsen / epileren',
      'Ampullen met hyaluronzuur',
      'Uitgebreide gezicht-, nek- en schoudermassage',
      'Masker',
      'Dag- of nachtverzorging',
      'Adviesgesprek',
    ],
  },
  {
    slug: 'power-c-glow-treatment',
    name: 'Power C Glow Treatment',
    previousName: 'Power Vitamine C Treatment',
    tagline: 'Glow & egalisatie voor een stralende huid met een gezonde teint.',
    duration: '60-75 min',
    price: '€72,50',
    description:
      'Huidverbeterende gezichtsbehandeling op basis van vitamine C. Ideaal bij een grauwe teint, pigmentvlekjes of de eerste tekenen van huidveroudering. Vitamine C stimuleert de celvernieuwing en collageenproductie, voor een heldere, gelijkmatige en egale teint.',
    idealFor: ['Grauwe huid', 'Ongelijkmatige teint', 'Pigmentvlekjes', 'Eerste lijntjes'],
    result: ['Meer glow', 'Egalere huid', 'Sterke antioxidantenbescherming', 'Stimulatie van collageen'],
    diamondCompatible: true,
    steps: [
      'Huidanalyse',
      'Reiniging',
      'Peeling',
      'Onzuiverheden verwijderen',
      'Wenkbrauwen harsen / epileren',
      'Ampullen met vitamine C',
      'Uitgebreide gezicht-, nek- en schoudermassage',
      'Masker',
      'Dag- of nachtverzorging',
      'Adviesgesprek',
    ],
  },
  {
    slug: 'power-retinol-lift-treatment',
    name: 'Power Retinol Lift Treatment',
    previousName: 'Power Retinol Treatment',
    tagline: 'Intensieve huidverjonging voor een stevigere, gladdere huid met minder rimpels.',
    duration: '60-75 min',
    price: '€82,50',
    description:
      'Huidverbeterende gezichtsbehandeling op basis van Pure Retinol, de meest intensieve anti-aging behandeling uit de Power-lijn. Ideaal bij diepere rimpels, huidverslapping, zonneschade of acne-littekens. Deze behandeling herstelt en verstevigt de huid en egaliseert het huidoppervlak, waardoor kleine littekens en huidvlekjes minder zichtbaar worden en de aanmaak van collageen en elastine wordt gestimuleerd.',
    idealFor: ['Diepere rimpels', 'Huidverslapping', 'Zonneschade', 'Acne-littekens', 'Pigment'],
    result: ['Gladdere huid', 'Minder rimpels', 'Verfijnde huidstructuur', 'Stevigere huid'],
    diamondCompatible: false,
    steps: [
      'Huidanalyse',
      'Reiniging',
      'Peeling',
      'Onzuiverheden verwijderen',
      'Wenkbrauwen harsen / epileren',
      'Ampullen met Pure Retinol',
      'Uitgebreide gezicht-, nek- en schoudermassage',
      'Masker',
      'Dag- of nachtverzorging',
      'Adviesgesprek',
    ],
  },
];

const diamondTreatment = {
  slug: 'art-of-beauty-diamond-treatment',
  name: 'Art of Beauty Diamond Treatment',
  isNew: true,
  price: '€82,50',
  description:
    'De Art of Beauty Treatment, standaard uitgebreid met microdermabrasie om dieper in de huidlaag te komen voor een extra stralend resultaat. Hiermee til je onze klassieke gezichtsbehandeling naar een hoger niveau.',
};

const allTreatmentsForSchema = [...powerTreatments, diamondTreatment, ...baseTreatments];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Gezichtsbehandeling',
  name: 'Huidverbeterende gezichtsbehandeling',
  description: 'Huidverbeterende gezichtsbehandelingen op maat bij Art of Beauty by Maelyn in Delft.',
  provider: { '@id': `${site.url}/#business` },
  areaServed: 'Delft',
  image: new URL('/images/treatments/gezichtsbehandeling.jpg', site.url).toString(),
  offers: allTreatmentsForSchema.map((t) => ({
    '@type': 'Offer',
    name: t.name,
    price: t.price.replace('€', '').replace(',', '.'),
    priceCurrency: 'EUR',
    availability: 'https://schema.org/InStock',
    url: site.bookingUrl,
  })),
};
---

<BaseLayout
  title="Facials / Gezichtsbehandeling - Art of Beauty by Maelyn Delft"
  description="Vind hier alle informatie over de verschillende facials / gezichtsbehandelingen welke wij aanbieden in onze schoonheidssalon in Delft!"
  image="/images/treatments/gezichtsbehandeling.jpg"
  schema={serviceSchema}
>
  <PageHero
    eyebrow="Behandeling"
    title="Huidverbeterende gezichtsbehandeling"
    lead="In onze schoonheidssalon in Delft bieden wij verschillende huidverbeterende gezichtsbehandelingen aan. Wij werken onder andere met de merken Paula's Choice en Skeyndor."
  />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <p class="text-ink-soft">
      Een huidverbeterende gezichtsbehandeling is een schoonheidsbehandeling die is ontworpen om
      de huidconditie te verbeteren en de huid te laten stralen. Dit kan gedaan worden door middel
      van een reiniging, exfoliatie, massage en/of maskers. Sommige behandelingen bevatten ook
      producten die specifiek gericht zijn op het verbeteren van de huid, zoals serum of crèmes
      met vitamines en antioxidanten. Het is aan te raden om een professionele
      schoonheidsspecialist te raadplegen om te bepalen welke behandeling het beste bij jouw
      huidtype en -behoeften past.
    </p>
    <p class="mt-4 text-ink-soft">
      Je kunt bij Art of Beauty by Maelyn terecht voor professionele, effectieve en ontspannen
      gezichtsbehandelingen. De gezichtsbehandelingen zijn gericht op huidverbetering en werken in
      op de diepere huidlagen: de huidstructuur verbetert en eventuele oneffenheden worden
      verminderd. Door de gezichtsbehandeling af te stemmen op de huidconditie en huidtype kunnen
      we samen werken aan een gezonde huid!
    </p>
  </section>

  <section class="px-6 md:px-10" data-reveal>
    <a href={site.bookingUrl} class="group relative block aspect-[16/7] w-full overflow-hidden bg-bg-soft md:aspect-[16/6]">
      <img
        src="/images/treatments/gezichtsbehandeling.jpg"
        alt="Gezichtsbehandeling bij Art of Beauty by Maelyn"
        class="h-full w-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.03]"
        loading="lazy"
      />
      <span class="absolute left-5 top-5 text-[11px] uppercase tracking-[0.18em] text-white/95 md:left-7 md:top-7">
        Gezichtsbehandelingen
      </span>
    </a>
  </section>

  <section class="bg-bg-soft py-16">
    <div class="mx-auto max-w-4xl px-6">
      <h2 class="font-display text-2xl text-ink sm:text-3xl">Power Treatments</h2>
      <p class="mt-2 text-sm text-ink-soft">Gerichte huidverbetering met hoogwaardige actieve ingrediënten.</p>
      <div class="mt-8 space-y-6">
        {
          powerTreatments.map((t) => (
            <div id={t.slug} class="scroll-mt-24 rounded-2xl border border-line bg-bg p-6">
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <h3 class="flex flex-wrap items-center gap-2 font-display text-xl text-ink">
                  {t.name}
                  {t.isNew && (
                    <span class="rounded-full bg-accent px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.08em] text-white">
                      Nieuw
                    </span>
                  )}
                </h3>
                <span class="text-sm font-medium text-ink-soft">{t.duration} · {t.price}</span>
              </div>
              {t.previousName && <p class="mt-0.5 text-xs italic text-ink-soft/70">Voorheen: {t.previousName}</p>}
              <p class="mt-2 text-sm font-medium text-accent">{t.tagline}</p>
              <p class="mt-3 text-ink-soft">{t.description}</p>

              <div class="mt-5 grid gap-6 sm:grid-cols-2">
                <div>
                  <p class="text-[11px] uppercase tracking-[0.1em] text-ink-soft">Ideaal voor</p>
                  <ul class="mt-2 space-y-1 text-sm text-ink-soft">
                    {t.idealFor.map((item) => (
                      <li class="flex items-start gap-2">
                        <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-accent-dark" />
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <p class="text-[11px] uppercase tracking-[0.1em] text-ink-soft">Resultaat</p>
                  <ul class="mt-2 space-y-1 text-sm text-ink-soft">
                    {t.result.map((item) => (
                      <li class="flex items-start gap-2">
                        <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-accent-dark" />
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <p class="mt-5 text-[11px] uppercase tracking-[0.1em] text-ink-soft">Behandeling</p>
              <ul class="mt-2 grid gap-x-6 gap-y-1 text-sm text-ink-soft sm:grid-cols-2">
                {t.steps.map((step) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-accent-dark" />
                    {step}
                  </li>
                ))}
              </ul>

              {t.diamondCompatible ? (
                <div class="mt-5 rounded-xl border border-accent/30 bg-accent/5 px-4 py-3">
                  <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-accent">
                    Uit te breiden met de Diamond Upgrade (+ € 20)
                  </p>
                  <p class="mt-1 text-xs text-ink-soft">
                    We voegen dan een microdermabrasie-stap toe die dieper in de huidlaag reikt,
                    voor een extra stralend en verfijnd resultaat.
                  </p>
                </div>
              ) : (
                <div class="mt-5 rounded-xl border border-line bg-line/30 px-4 py-3">
                  <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-ink-soft">
                    Niet te combineren met de Diamond Upgrade
                  </p>
                  <p class="mt-1 text-xs text-ink-soft">
                    Deze behandeling werkt al zeer intensief op de huid, daarom voegen we hier geen
                    extra microdermabrasie-stap aan toe.
                  </p>
                </div>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-4xl px-6">
      <h2 class="font-display text-2xl text-ink sm:text-3xl">Art of Beauty Diamond Treatment</h2>
      <p class="mt-2 text-sm text-ink-soft">Onze klassieke behandeling, standaard met de Diamond Upgrade.</p>
      <div class="mt-8">
        <div id={diamondTreatment.slug} class="scroll-mt-24 rounded-2xl border border-line bg-bg-soft p-6">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="flex flex-wrap items-center gap-2 font-display text-xl text-ink">
              {diamondTreatment.name}
              {diamondTreatment.isNew && (
                <span class="rounded-full bg-accent px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.08em] text-white">
                  Nieuw
                </span>
              )}
            </h3>
            <span class="text-sm font-medium text-ink-soft">{diamondTreatment.price}</span>
          </div>
          <p class="mt-3 text-ink-soft">{diamondTreatment.description}</p>
          <a href="/microdermabrasie/" class="mt-4 inline-block text-sm text-accent underline decoration-accent underline-offset-4">
            Meer over microdermabrasie
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-bg-soft py-16">
    <div class="mx-auto max-w-4xl px-6">
      <h2 class="font-display text-2xl text-ink sm:text-3xl">Basis gezichtsbehandelingen</h2>
      <p class="mt-2 text-sm text-ink-soft">Onze onderhouds- en verzorgingsbehandelingen.</p>
      <div class="mt-8 space-y-6">
        {
          baseTreatments.map((t) => (
            <div class="rounded-2xl border border-line bg-bg p-6">
              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <h3 class="font-display text-xl text-ink">{t.name}</h3>
                <span class="text-sm font-medium text-ink-soft">{t.duration} · {t.price}</span>
              </div>
              <p class="mt-3 text-ink-soft">{t.description}</p>
              <ul class="mt-4 grid gap-x-6 gap-y-1 text-sm text-ink-soft sm:grid-cols-2">
                {t.steps.map((step) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-accent-dark" />
                    {step}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="mx-auto max-w-4xl px-6">
      <h2 class="font-display text-2xl text-ink sm:text-3xl">Uitbreiding mogelijk</h2>
      <p class="mt-2 text-ink-soft">
        Elke Power Treatment is uit te breiden met de Diamond Upgrade.
      </p>

      <div class="mt-8 rounded-2xl border border-accent/30 bg-accent/5 p-6">
        <p class="text-[11px] font-semibold uppercase tracking-[0.08em] text-accent">
          Diamond Upgrade (+ € 20)
        </p>
        <p class="mt-2 text-ink-soft">
          Bij de Diamond Upgrade voegen we een microdermabrasie-stap toe aan je behandeling,
          zodat we nog dieper in de huidlaag komen voor een extra stralend en verfijnd resultaat.
          Deze upgrade is te combineren met de Power C Glow, Power Hydration en Power Oxygen
          Treatment, maar niet met de Power Retinol Lift Treatment.
        </p>
        <a href="/microdermabrasie/" class="mt-3 inline-block text-sm text-accent underline decoration-accent underline-offset-4">
          Meer over microdermabrasie
        </a>
      </div>
    </div>
  </section>

  <section class="py-12">
    <div class="mx-auto max-w-4xl px-6">
      <p class="text-sm text-ink-soft">
        Voor de meest actuele prijzen bekijk je onze <a href={site.bookingUrl} class="underline decoration-accent underline-offset-4">online afsprakenmodule</a>.
      </p>
      <Button href={site.bookingUrl} class="mt-8">Afspraak maken</Button>
    </div>
  </section>
</BaseLayout>
