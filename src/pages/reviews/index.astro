---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Button from '../../components/Button.astro';
---

<BaseLayout
  title="Reviews - Art of Beauty by Maelyn"
  description="Tevreden klanten staat bij ons op nummer 1. Massage of schoonheidsbehandeling bij ons in de schoonheidssalon gehad? Bekijk hier de reviews."
>
  <PageHero
    eyebrow="Reviews"
    title="Wat klanten over ons zeggen"
    lead="Tevreden klanten staan bij ons op nummer 1."
  />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <div class="overflow-hidden rounded-2xl border border-line bg-bg-soft">
      <iframe
        title="Reviews Art of Beauty by Maelyn"
        src="https://art-of-beauty-by-maelyn.salonized.com/reviews?layout=embed"
        width="100%"
        height="900"
        style="border:0;"
        loading="lazy"
      ></iframe>
    </div>
    <p class="mt-8 text-sm text-ink-soft">
      Massage of schoonheidsbehandeling bij ons gehad? We horen graag je ervaring.
    </p>
    <Button href="/contact/" variant="outline" class="mt-4">Deel je review</Button>
  </section>
</BaseLayout>
