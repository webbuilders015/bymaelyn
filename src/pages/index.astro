---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import TreatmentIcon from '../components/TreatmentIcon.astro';
import { site, treatments } from '../data/site';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Art of Beauty by Maelyn | Schoonheidsspecialist Delft"
  description={site.description}
  image="/images/hero-home.webp"
>
  <section class="relative h-[62vh] min-h-[380px] w-full" data-reveal>
    <img
      src="/images/hero-home.webp"
      alt="Art of Beauty by Maelyn"
      class="h-full w-full object-cover"
    />
    <a
      href={site.bookingUrl}
      class="absolute bottom-5 right-5 inline-flex h-12 items-center rounded-full bg-accent px-6 text-[13px] tracking-[0.08em] text-bg shadow-lg shadow-ink/20 transition-colors hover:bg-accent-dark md:bottom-8 md:right-8"
    >
      Maak afspraak
    </a>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-16 text-center md:py-20" data-reveal>
    <p class="text-[11px] uppercase tracking-[0.18em] text-accent">Schoonheidsspecialist in Delft</p>
    <h1 class="mt-4 text-[15px] font-normal leading-relaxed tracking-normal text-ink-soft">
      Art of Beauty by Maelyn is een Anbos gecertificeerde schoonheidsspecialiste gevestigd op de
      Bagijnhof 1 aan de rand van het centrum van Delft.
    </h1>
    <h2 class="mx-auto mt-6 max-w-xl text-[15px] font-normal leading-relaxed text-ink-soft">
      In deze schoonheidssalon in Delft kun je terecht voor huidverbeterende
      gezichtsbehandelingen, ontspanningsmassages, wimperlifting, waxen en diverse losse
      schoonheidsbehandelingen.
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-[15px] leading-relaxed text-ink-soft">
      Ben je op zoek naar een schoonheidssalon waar kwaliteit, ontspanning en huidverbetering
      centraal staat? Dan ben je bij Art of Beauty by Maelyn in Delft aan het juiste adres!
      Mocht er in de online agenda geen geschikt plekje meer beschikbaar zijn, stuur dan even
      een <a href="/contact/" class="text-ink underline decoration-accent underline-offset-4">berichtje</a>,
      dan kan ik altijd even kijken wat de mogelijkheden zijn.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <Button href={site.bookingUrl}>Afspraak maken</Button>
      <Button href="/behandelingen/" variant="outline">Bekijk behandelingen</Button>
    </div>
  </section>

  <section class="bg-bg-soft px-6 py-16 md:px-10 md:py-20" data-reveal>
    <div class="mx-auto max-w-6xl">
      <p class="mb-8 text-[11px] uppercase tracking-[0.16em] text-ink-soft">Behandelingen</p>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 md:gap-10 lg:grid-cols-5">
        {
          treatments.map((t) => (
            <a href={`/${t.slug}/`} class="group flex h-full flex-col">
              <div class="relative flex aspect-square w-full items-center justify-center overflow-hidden rounded-2xl bg-bg transition-colors duration-300 group-hover:bg-accent/10">
                <TreatmentIcon name={t.icon} class="h-12 w-12 text-accent-dark transition-transform duration-500 group-hover:scale-110 sm:h-14 sm:w-14" />
              </div>
              <div class="flex flex-1 flex-col items-center px-1 pt-5 text-center">
                <span class="text-[15px] tracking-tight text-ink">{t.title}</span>
                <p class="mt-1.5 max-w-[32ch] text-[12px] leading-relaxed text-ink-soft">{t.short}</p>
              </div>
              <span class="mx-1 mt-5 flex h-11 items-center justify-center rounded-full border border-ink/20 text-[12px] tracking-wide transition-colors duration-300 group-hover:border-accent group-hover:bg-accent group-hover:text-bg">
                Bekijken
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-6 py-16 md:px-10 md:py-24" data-reveal>
    <div class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-10 md:grid-cols-12 md:gap-16">
      <div class="md:col-span-5">
        <div class="relative aspect-[4/5] w-full max-w-xs overflow-hidden rounded-3xl bg-bg-soft md:max-w-sm">
          <img
            src="/images/cadeaubon.jpg"
            alt="Cadeaubon Art of Beauty by Maelyn"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
      <div class="md:col-span-7">
        <p class="text-[11px] uppercase tracking-[0.16em] text-ink-soft">Cadeau</p>
        <h2 class="mt-3 font-display text-[26px] font-light leading-tight tracking-tight text-ink md:text-[34px]">
          Geef een beauty cadeaubon
        </h2>
        <p class="mt-6 max-w-md text-[13px] leading-relaxed text-ink-soft">
          Op zoek naar een origineel cadeau? Geef een cadeaubon voor een behandeling of
          skincare-producten van Paula's Choice of Skeyndor. De ontvanger bepaalt zelf welke
          behandeling of welk bedrag het beste past.
        </p>
        <a
          href="/cadeaubon/"
          class="mt-8 inline-flex h-12 items-center rounded-full border border-ink/20 px-10 text-[13px] transition-colors duration-300 hover:border-accent hover:bg-accent hover:text-bg"
        >
          Meer over de cadeaubon
        </a>
      </div>
    </div>
  </section>

  <section class="px-6 py-16 md:px-10 md:py-24" data-reveal>
    <div class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-10 md:grid-cols-12 md:gap-16">
      <div class="order-2 md:order-1 md:col-span-5">
        <h2 class="font-display text-[26px] font-light leading-tight tracking-tight text-ink md:text-[34px]">
          Huidverbetering op maat
        </h2>
        <div class="mt-6 space-y-3 text-[13px] leading-relaxed text-ink-soft">
          <p>
            Elke huid is anders. Daarom beginnen we iedere behandeling met een huidanalyse en
            stemmen we de aanpak af op jouw huidtype en wensen.
          </p>
          <p>
            We werken met Skeyndor en Paula's Choice: twee merken die stoelen op wetenschappelijk
            onderbouwde, effectieve huidverzorging &mdash; zonder loze beloftes.
          </p>
        </div>
        <a href="/gezichtsbehandeling/" class="mt-10 inline-flex h-12 items-center rounded-full border border-ink/20 px-10 text-[13px] transition-colors duration-300 hover:border-accent hover:bg-accent hover:text-bg">
          Meer over onze behandelingen
        </a>
      </div>
      <div class="order-1 md:order-2 md:col-span-7">
        <div class="relative aspect-[16/11] w-full overflow-hidden rounded-3xl bg-bg-soft">
          <img
            src="/images/treatments/gezichtsbehandeling.jpg"
            alt="Gezichtsbehandeling bij Art of Beauty by Maelyn"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  {
    posts.length > 0 && (
      <section class="bg-bg-soft px-6 py-16 md:px-10 md:py-24" data-reveal>
        <div class="mx-auto max-w-6xl">
          <div class="flex items-end justify-between gap-4">
            <p class="text-[11px] uppercase tracking-[0.16em] text-ink-soft">Huidverzorging tips &amp; informatie</p>
            <a href="/blog/" class="text-[12px] uppercase tracking-[0.1em] text-accent hover:opacity-70">
              Alle artikelen
            </a>
          </div>
          <div class="mt-8 grid gap-6 sm:grid-cols-3">
            {posts.map((post) => (
              <a
                href={`/blog/${post.id}/`}
                class="group flex flex-col overflow-hidden rounded-2xl border border-line bg-bg transition-colors hover:border-ink/40"
              >
                <div class="aspect-[16/10] w-full overflow-hidden">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.heroAlt}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="flex flex-1 flex-col p-6">
                  <span class="text-[11px] uppercase tracking-[0.1em] text-accent">
                    {post.data.tags[0] ?? 'Skincare'}
                  </span>
                  <span class="mt-2 font-display text-[17px] tracking-tight text-ink">
                    {post.data.title}
                  </span>
                  <span class="mt-2 text-[13px] leading-relaxed text-ink-soft">{post.data.description}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="px-6 py-16 md:px-10 md:py-24" data-reveal>
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-12 lg:grid-cols-2">
      <div>
        <h2 class="font-display text-2xl text-ink">Contact</h2>
        <p class="mt-3 max-w-lg text-[13px] leading-relaxed text-ink-soft">
          Voor vragen kun je contact opnemen via onderstaand contactformulier. We streven ernaar
          binnen 24 uur antwoord te geven op je vraag.
        </p>

        <form id="home-contact-form" class="mt-6 grid gap-4 sm:grid-cols-2" method="post">
          <input
            type="text"
            name="name"
            placeholder="Naam"
            required
            class="rounded-2xl border border-line bg-bg px-4 py-3 text-[14px] text-ink outline-none focus:border-accent"
          />
          <input
            type="email"
            name="email"
            placeholder="E-mailadres"
            required
            class="rounded-2xl border border-line bg-bg px-4 py-3 text-[14px] text-ink outline-none focus:border-accent"
          />
          <input
            type="tel"
            name="phone"
            placeholder="Telefoonnummer"
            class="rounded-2xl border border-line bg-bg px-4 py-3 text-[14px] text-ink outline-none focus:border-accent sm:col-span-2"
          />
          <textarea
            name="message"
            placeholder="Je bericht"
            rows="5"
            required
            class="rounded-2xl border border-line bg-bg px-4 py-3 text-[14px] text-ink outline-none focus:border-accent sm:col-span-2"
          ></textarea>
          <button
            type="submit"
            class="inline-flex h-12 w-fit items-center rounded-full bg-accent px-8 text-[13px] uppercase tracking-[0.08em] text-bg transition-colors hover:bg-accent-dark disabled:opacity-60 sm:col-span-2"
          >
            Verstuur
          </button>
          <p id="home-contact-form-status" class="text-sm sm:col-span-2" role="status"></p>
        </form>
      </div>

      <div class="rounded-3xl border border-line bg-bg-soft p-8 md:p-10">
        <h2 class="font-display text-2xl text-ink">Openingstijden</h2>
        <ul class="mt-5 space-y-2.5 text-[14px] text-ink-soft">
          {
            site.openingHours.map((o) => (
              <li class="flex items-center justify-between gap-4 border-b border-line/70 pb-2.5 last:border-0 last:pb-0">
                <span>{o.day}</span>
                <span class="text-ink">{o.hours}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="px-6 py-16 md:px-10 md:py-24" data-reveal>
    <div class="mx-auto max-w-6xl overflow-hidden rounded-3xl border border-line bg-bg-soft px-6 py-14 text-center md:px-12 md:py-20">
      <h2 class="font-display text-[30px] font-light leading-none tracking-tight text-ink md:text-[44px]">
        {site.name}
      </h2>
      <p class="mt-6 text-[11px] uppercase tracking-[0.18em] text-ink-soft">Plan je afspraak</p>
      <p class="mx-auto mt-3 max-w-[36ch] text-[13px] leading-relaxed text-ink-soft md:text-[14px]">
        Boek eenvoudig online je gezichtsbehandeling, massage of andere schoonheidsbehandeling.
      </p>
      <a
        href={site.bookingUrl}
        class="mt-7 inline-flex h-12 items-center rounded-full bg-accent px-8 text-[12px] uppercase tracking-[0.1em] text-bg transition-colors hover:bg-accent-dark"
      >
        Afspraak maken
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('home-contact-form') as HTMLFormElement | null;
  const status = document.getElementById('home-contact-form-status');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (button) button.disabled = true;
    if (status) {
      status.textContent = 'Bezig met versturen...';
      status.className = 'text-sm sm:col-span-2 text-ink-soft';
    }

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(form),
      });
      const result = await response.json();

      if (response.ok && result.success) {
        form.reset();
        if (status) {
          status.textContent = 'Bedankt! Je bericht is verstuurd, we nemen snel contact op.';
          status.className = 'text-sm sm:col-span-2 text-emerald-600';
        }
      } else {
        if (status) {
          status.textContent = result.error || 'Versturen is niet gelukt. Probeer het later opnieuw.';
          status.className = 'text-sm sm:col-span-2 text-red-600';
        }
      }
    } catch {
      if (status) {
        status.textContent = 'Versturen is niet gelukt. Controleer je internetverbinding.';
        status.className = 'text-sm sm:col-span-2 text-red-600';
      }
    } finally {
      if (button) button.disabled = false;
    }
  });
</script>
