---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { site, treatments } from '../data/site';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Art of Beauty by Maelyn | Schoonheidsspecialist Delft"
  description={site.description}
>
  <section class="mx-auto max-w-6xl px-6 pb-16 pt-14 sm:pt-20">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-terracotta-dark">
          Schoonheidsspecialist in Delft
        </p>
        <h1 class="mt-4 font-display text-4xl leading-tight text-ink sm:text-5xl">
          Art of Beauty by Maelyn is een Anbos gecertificeerde schoonheidsspecialiste gevestigd
          op de Bagijnhof 1 aan de rand van het centrum van Delft.
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-ink-soft">
          In deze schoonheidssalon in Delft kun je terecht voor huidverbeterende
          gezichtsbehandelingen, ontspanningsmassages, wimperlifting, waxen en diverse losse
          schoonheidsbehandelingen.
        </p>
        <p class="mt-4 leading-relaxed text-ink-soft">
          Ben je op zoek naar een schoonheidssalon waar kwaliteit, ontspanning en huidverbetering
          centraal staat? Dan ben je bij Art of Beauty by Maelyn in Delft aan het juiste adres!
          Mocht er in de online agenda geen geschikt plekje meer beschikbaar zijn, stuur dan even
          een <a href="/contact/" class="underline decoration-terracotta underline-offset-4">berichtje</a>,
          dan kan ik altijd even kijken wat de mogelijkheden zijn.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href={site.bookingUrl}>Afspraak maken</Button>
          <Button href="/behandelingen/" variant="outline">Bekijk behandelingen</Button>
        </div>
      </div>
      <div class="overflow-hidden rounded-3xl bg-blush/40">
        <img
          src="/images/hero-salon.jpg"
          alt="Art of Beauty by Maelyn, schoonheidssalon in Delft"
          class="h-full w-full object-cover"
          width="800"
          height="960"
        />
      </div>
    </div>
  </section>

  <section class="bg-cream-dark/60 py-16">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="font-display text-2xl text-ink sm:text-3xl">Behandelingen</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          treatments.map((t) => (
            <a
              href={`/${t.slug}/`}
              class="group flex flex-col rounded-2xl border border-line bg-cream p-6 transition-shadow hover:shadow-lg hover:shadow-ink/5"
            >
              <span class="font-display text-lg text-ink group-hover:text-terracotta-dark">
                {t.title}
              </span>
              <span class="mt-2 text-sm text-ink-soft">{t.short}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {
    posts.length > 0 && (
      <section class="mx-auto max-w-6xl px-6 py-16">
        <div class="flex items-end justify-between gap-4">
          <h2 class="font-display text-2xl text-ink sm:text-3xl">Van de blog</h2>
          <a href="/blog/" class="text-sm font-medium text-terracotta-dark hover:underline">
            Alle artikelen
          </a>
        </div>
        <div class="mt-8 grid gap-6 sm:grid-cols-3">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="flex flex-col rounded-2xl border border-line bg-cream p-6 transition-shadow hover:shadow-lg hover:shadow-ink/5"
            >
              <span class="text-xs uppercase tracking-wide text-terracotta-dark">
                {post.data.tags[0] ?? 'Skincare'}
              </span>
              <span class="mt-2 font-display text-lg text-ink">{post.data.title}</span>
              <span class="mt-2 text-sm text-ink-soft">{post.data.description}</span>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <section class="mx-auto max-w-6xl px-6 pb-20">
    <div class="grid gap-10 rounded-3xl bg-blush/40 p-10 sm:grid-cols-2">
      <div>
        <h2 class="font-display text-2xl text-ink">Contact</h2>
        <p class="mt-3 text-ink-soft">
          Voor vragen kun je contact opnemen via het contactformulier. We streven ernaar binnen 24
          uur antwoord te geven op je vraag.
        </p>
        <Button href="/contact/" variant="outline" class="mt-6">Naar contact</Button>
      </div>
      <div>
        <h2 class="font-display text-2xl text-ink">Openingstijden</h2>
        <ul class="mt-3 space-y-1 text-ink-soft">
          {
            site.openingHours
              .filter((o) => o.hours !== 'Gesloten')
              .map((o) => (
                <li class="flex justify-between gap-4">
                  <span>{o.day}</span>
                  <span>{o.hours}</span>
                </li>
              ))
          }
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
