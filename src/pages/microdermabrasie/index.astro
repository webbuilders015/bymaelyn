---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Button from '../../components/Button.astro';
import { site } from '../../data/site';
import { getCollection } from 'astro:content';

const relatedSlugs = ['chemische-peeling-vs-microdermabrasie', 'huidverbeterende-gezichtsbehandeling-uitgelegd'];
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = relatedSlugs
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const reasons = [
  'Verwijdert de dode huidcellen van de bovenste huidlaag.',
  'Geeft direct een frisse, stralende glow.',
  'Verfijnt en minimaliseert de poriën.',
  'Stimuleert de doorbloeding en celvernieuwing.',
  'Vermindert oppervlakkige oneffenheden en littekentjes.',
  'Verbetert de opname van verzorgingsproducten.',
  'Geen hersteltijd nodig, ideaal voor een speciale gelegenheid.',
  'Geschikt voor de meeste huidtypes.',
];

const steps = ['Huidanalyse & intake', 'Reiniging', 'Microdermabrasie', 'Kalmerend & beschermend masker'];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Microdermabrasie',
  name: 'Microdermabrasie',
  description: 'Mechanische peeling voor een directe glow en verfijnde poriën, bij Art of Beauty by Maelyn in Delft.',
  provider: { '@id': `${site.url}/#business` },
  areaServed: 'Delft',
  image: new URL('/images/treatments/microdermabrasie.jpg', site.url).toString(),
  offers: {
    '@type': 'Offer',
    url: site.bookingUrl,
    availability: 'https://schema.org/InStock',
  },
};
---

<BaseLayout
  title="Microdermabrasie - Art of Beauty by Maelyn"
  description="Microdermabrasie bij Art of Beauty by Maelyn in Delft: een mechanische peeling voor een directe glow, verfijnde poriën en een frissere huid."
  image="/images/treatments/microdermabrasie.jpg"
  schema={serviceSchema}
>
  <PageHero
    eyebrow="Behandeling"
    title="Microdermabrasie"
    lead="Een mechanische peeling die de dode huidlaag verwijdert voor een directe glow, verfijnde poriën en een frissere, gladdere huid."
  />

  <section class="px-6 md:px-10" data-reveal>
    <a href={site.bookingUrl} class="group relative block aspect-[16/7] w-full overflow-hidden bg-bg-soft md:aspect-[16/6]">
      <img
        src="/images/treatments/microdermabrasie.jpg"
        alt="Microdermabrasie behandeling bij Art of Beauty by Maelyn"
        class="h-full w-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.03]"
        loading="lazy"
      />
      <span class="absolute left-5 top-5 text-[11px] uppercase tracking-[0.18em] text-white/95 md:left-7 md:top-7">
        Microdermabrasie
      </span>
    </a>
  </section>

  <section class="mx-auto max-w-4xl px-6 py-16">
    <p class="text-ink-soft">
      Microdermabrasie is een niet-invasieve, mechanische peeling waarbij de bovenste, dode
      huidlaag voorzichtig wordt weggeslepen met een diamanten kop of fijne kristallen. Het
      resultaat: een direct zichtbare glow, een verfijnde huidstructuur en poriën die minder
      opvallen. Deze behandeling voegen we graag toe aan ons aanbod voor iedereen die op korte
      termijn een frissere huid wil, zonder hersteltijd.
    </p>

    <h2 class="mt-12 font-display text-2xl text-ink">Wat is microdermabrasie?</h2>
    <p class="mt-4 text-ink-soft">
      In tegenstelling tot een chemische peeling werkt microdermabrasie mechanisch: de dode
      huidcellen worden fysiek weggeslepen in plaats van chemisch losgeweekt. Dit maakt het een
      oppervlakkige behandeling die perfect is voor een snelle opfrisser, bijvoorbeeld voor een
      speciale gelegenheid, of als aanvulling op een reguliere gezichtsbehandeling.
    </p>
    <p class="mt-4 text-ink-soft">
      Twijfel je tussen microdermabrasie en een chemische peeling? Lees het verschil in onze
      <a href="/blog/chemische-peeling-vs-microdermabrasie/" class="text-accent underline">blog</a>
      of bespreek het tijdens de huidanalyse — samen bepalen we wat het beste bij jouw huid past.
    </p>

    <h2 class="mt-12 font-display text-2xl text-ink">Waarom microdermabrasie?</h2>
    <ol class="mt-4 grid gap-2 sm:grid-cols-2">
      {
        reasons.map((r, i) => (
          <li class="flex items-start gap-3 text-ink-soft">
            <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent/15 text-xs font-semibold text-accent">
              {i + 1}
            </span>
            {r}
          </li>
        ))
      }
    </ol>

    <h2 class="mt-12 font-display text-2xl text-ink">Hoe ziet een behandeling eruit?</h2>
    <p class="mt-4 text-ink-soft">
      Elke behandeling start met een huidanalyse en intakegesprek, zodat we de aanpak kunnen
      afstemmen op jouw huidtype en wensen.
    </p>
    <ol class="mt-3 grid grid-cols-2 gap-3 sm:flex sm:flex-wrap">
      {
        steps.map((step, i) => (
          <li class="flex items-center justify-center rounded-2xl border border-line bg-bg-soft px-4 py-2 text-center text-sm text-ink-soft sm:rounded-full">
            {i + 1}. {step}
          </li>
        ))
      }
    </ol>

    {
      relatedPosts.length > 0 && (
        <div class="mt-14 border-t border-line pt-10">
          <p class="text-[11px] uppercase tracking-[0.16em] text-ink-soft">Lees ook op onze blog</p>
          <div class="mt-5 grid gap-5 sm:grid-cols-2">
            {relatedPosts.map((post) => (
              <a
                href={`/blog/${post.id}/`}
                class="group flex flex-col overflow-hidden rounded-2xl border border-line bg-bg-soft transition-colors hover:border-ink/40"
              >
                <div class="aspect-[16/10] w-full overflow-hidden">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.heroAlt}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="flex flex-1 flex-col p-5">
                  <span class="text-[11px] uppercase tracking-[0.1em] text-accent">{post.data.tags[0] ?? 'Skincare'}</span>
                  <span class="mt-2 font-display text-[16px] leading-snug text-ink">{post.data.title}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )
    }

    <Button href={site.bookingUrl} class="mt-10">Afspraak maken</Button>
  </section>
</BaseLayout>
